# DeFi资产展示服务环境变量配置

# 服务配置
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_MODE=release

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=defi_user
DB_PASSWORD=defi_password
DB_NAME=defi_asset_service

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# 外部服务API密钥
SERVICE_A_API_KEY=your_service_a_api_key
SERVICE_B_API_KEY=your_service_b_api_key
DEBANK_API_KEY=your_debank_api_key

# 认证配置
JWT_SECRET=your-jwt-secret-key-here-change-in-production
API_KEY_HEADER=X-API-Key

# 日志配置
LOG_LEVEL=info
LOG_FORMAT=json
LOG_OUTPUT=stdout

# 监控配置
PROMETHEUS_ENABLED=true
HEALTH_CHECK_ENABLED=true

# 定时任务配置
CRON_SYNC_PROTOCOLS_ENABLED=true
CRON_CLEANUP_CACHE_ENABLED=true
CRON_UPDATE_PRICES_ENABLED=true